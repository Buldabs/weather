        <mxCell id="edge-include-delete" edge="1" parent="1" source="uc-remove-favorite" style="dashed=1;dashPattern=8 8;" target="uc-delete-from-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="label-include-delete" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&amp;lt;include&amp;gt;" vertex="1">
          <mxGeometry height="20" width="80" x="440" y="550" as="geometry" />
        </mxCell>
        <mxCell id="edge-extend-error" edge="1" parent="1" source="uc-find-weather" style="dashed=1;dashPattern=8 8;" target="uc-show-error">
          <mxGeometry relative="1" as="geometry">
