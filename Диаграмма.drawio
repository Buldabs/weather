        <mxCell id="label-include-save" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&amp;lt;include&amp;gt;" vertex="1">
          <mxGeometry height="20" width="80" x="330" y="340" as="geometry" />
        </mxCell>
        <mxCell id="edge-include-load" edge="1" parent="1" source="uc-view-favorites" style="dashed=1;dashPattern=8 8;" target="uc-load-from-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="label-include-load" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&amp;lt;include&amp;gt;" vertex="1">
          <mxGeometry height="20" width="80" x="870" y="230" as="geometry" />
